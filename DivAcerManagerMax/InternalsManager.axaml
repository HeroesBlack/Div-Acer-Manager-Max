<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DivAcerManagerMax.InternalsManager"
        Width="600" Height="700"
        Title="DAMX Internals Manager"
        Icon="iconTransparent.png"
        WindowStartupLocation="CenterOwner"
        Background="#0e0e11">

    <Grid>
        <Grid RowDefinitions="Auto,*">

            <!-- Header -->
            <Border Grid.Row="0" Padding="0 10 0 10">
                <TextBlock Text="Gestione Avanzata" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontFamily="{StaticResource OxaniumBoldFont}">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%, 100%">
                            <GradientStop Offset="0" Color="#72bff4" />
                            <GradientStop Offset="1" Color="#3678c3" />
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>
            </Border>

            <!-- Main Content -->
            <ScrollViewer Grid.Row="1" Margin="15,0,15,15">
                <StackPanel>

                    <!-- Developer Mode -->
                    <Border Classes="Card" Margin="0,0,0,15">
                        <StackPanel>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Modalità Sviluppatore" Classes="SubHeader"
                                           VerticalAlignment="Center" />
                                <ToggleSwitch x:Name="DevModeToggleSwitch" Grid.Column="1"
                                              VerticalAlignment="Center"
                                              Click="DevModeSwitch_OnClick" />
                            </Grid>
                            <TextBlock Text="Abilita controlli avanzati e override funzionalità"
                                       Opacity="0.7" Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Driver Parameters -->
                    <Border Classes="Card" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Parametri Driver" Classes="SubHeader" />
                            <TextBlock Text="Carica i driver con parametri specifici (solo una volta)"
                                       Opacity="0.7" Margin="0,0,0,15" />

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                                        Margin="0,0,0,10">
                                <Button x:Name="ForceNitroButton"
                                        Content="Carica con nitro_v4"
                                        Click="ForceNitroButton_OnClick"
                                        Margin="0,0,10,0"
                                        MinWidth="120" />
                                <Button x:Name="ForcePredatorButton"
                                        Content="Carica con predator_v4"
                                        Click="ForcePredatorButton_OnClick"
                                        Margin="0,0,10,0"
                                        MinWidth="120" />
                                <Button x:Name="ForceEnableAll"
                                        Content="Carica con enable_all"
                                        Click="ForceEnableAll_OnClick"
                                        MinWidth="120" />
                            </StackPanel>

                            <TextBlock Text="I parametri vengono cancellati al riavvio se il forzamento permanente non è abilitato"
                                       Opacity="0.5" HorizontalAlignment="Left"
                                       TextAlignment="Center" FontSize="11" />
                        </StackPanel>
                    </Border>

                    <!-- Permanent Model Override -->
                    <Border Classes="Card" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Override Modello Permanente" Classes="SubHeader" />
                            <TextBlock Text="Forza un modello specifico in modo permanente per dispositivi non supportati o problematici"
                                       Opacity="0.7" Margin="0,0,0,15" />

                            <ComboBox x:Name="ForceParameterPermanentlyComboBox"
                                      SelectedIndex="0"
                                      HorizontalAlignment="Left"
                                      MinWidth="280">
                                <ComboBoxItem Content="Disabilitato" />
                                <ComboBoxItem Content="Forza Modello Predator (predator_v4)" />
                                <ComboBoxItem Content="Forza Modello Nitro (nitro_v4)" />
                                <ComboBoxItem Content="Forza Tutte le Funzionalità (enable_all)" />

                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- System Restart Controls -->
                    <Border Classes="Card" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Controlli Riavvio" Classes="SubHeader" />
                            <TextBlock Text="Riavvia i componenti di sistema per applicare le modifiche"
                                       Opacity="0.7" Margin="0,0,0,15" />

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                                        Margin="0,0,0,10">
                                <Button x:Name="RestartSuiteButton"
                                        Content="Riavvia Driver e Daemon"
                                        Click="RestartSuiteButton_OnClick"
                                        Margin="0,0,15,0"
                                        MinWidth="180" />
                                <Button x:Name="RestartDaemon"
                                        Content="Riavvia solo Daemon"
                                        Click="RestartDaemon_OnClick"
                                        MinWidth="140" />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="• Riavvia entrambi: reset completo, cancella tutti i parametri"
                                           Opacity="0.6" FontSize="12"
                                           HorizontalAlignment="Left" />
                                <TextBlock Text="• Riavvia daemon: aggiorna le funzionalità con i parametri correnti"
                                           Opacity="0.6" FontSize="12"
                                           HorizontalAlignment="Left" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Debug Tools -->
                    <Border Classes="Card">
                        <StackPanel>
                            <TextBlock Text="Strumenti Debug" Classes="SubHeader" />
                            <TextBlock Text="Accedi a informazioni diagnostiche e log"
                                       Opacity="0.7" Margin="0,0,0,15" />

                            <Button x:Name="DaemonLogsButton"
                                    Content="Visualizza Log Daemon"
                                    Click="DaemonLogsButton_OnClick"
                                    HorizontalAlignment="Left"
                                    MinWidth="160" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>

</Window>